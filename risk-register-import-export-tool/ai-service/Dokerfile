# Use an official lightweight Python runtime
FROM python:3.11-slim

# Set the working directory in the container
WORKDIR /app

# Copy the requirements file first to optimize Docker layers
COPY requirements.txt .

# Install the dependencies specified in your requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy the entire ai-service folder into the container
COPY . .

# The AI service runs on port 5000
EXPOSE 5000

# Start the Flask application
CMD ["python", "app.py"]