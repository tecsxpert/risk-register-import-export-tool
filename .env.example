SERVER_PORT=8080
AI_SERVICE_PORT=5000
FRONTEND_PORT=5173

DB_HOST=postgres
DB_PORT=5432
DB_NAME=risk_register_import_export_tool_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

REDIS_HOST=redis
REDIS_PORT=6379
